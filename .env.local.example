# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini (khung chat tra cứu /chat) — chỉ dùng phía server
# Bắt buộc ít nhất GEMINI_API_KEY. Có thể thêm _2.._6 để xoay vòng né giới hạn ngày.
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
